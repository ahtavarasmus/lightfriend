# Parent Proxy Configuration
# Copy this file to .env and customize for your environment

# Path to the SQLite database (read-only access)
DATABASE_PATH=/path/to/database.db

# VSOCK configuration for old enclave (VPS migrating from)
OLD_ENCLAVE_CID=16
OLD_ENCLAVE_PORT=5000

# VSOCK configuration for new enclave (AWS)
NEW_ENCLAVE_CID=17
NEW_ENCLAVE_PORT=5000

# HTTP listen port (default: 3000)
LISTEN_PORT=3000

# Development mode only (non-Linux):
# These URLs are used when running on macOS/Windows for testing
# OLD_ENCLAVE_URL=http://localhost:3001
# NEW_ENCLAVE_URL=http://localhost:3002
