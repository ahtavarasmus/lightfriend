# Lightfriend Backend Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# CORE / AUTHENTICATION
# =============================================================================

# Database
DATABASE_URL=database.db

# Optional: read-only access to mautrix-whatsapp's PostgreSQL database.
# When set, the rule builder dropdown can list WhatsApp DM contacts that
# don't yet have a Matrix room (the bridge creates rooms lazily). Only
# meaningful inside the enclave where the bridge runs alongside the backend.
# WHATSAPP_BRIDGE_DATABASE_URL=postgres://whatsapp_user:whatsapp_password@localhost:5432/whatsapp_db

# JWT secrets (generate secure random strings)
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_REFRESH_KEY=your-jwt-refresh-key-here

# Encryption key (32-byte base64-encoded key for AES-256-GCM)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-base64-encoded-32-byte-key-here

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Environment: development, staging, or self_hosted
ENVIRONMENT=development

# Server URLs
SERVER_URL=https://your-domain.com
SERVER_URL_OAUTH=https://your-domain.com
FRONTEND_URL=http://localhost:8080

# =============================================================================
# TWILIO SMS/VOICE
# =============================================================================

# Main Twilio account credentials
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Set to true to disable actual Twilio API calls (for testing)
TWILIO_MOCK_MODE=false

# Regulatory bundle SIDs (required for UK/AU phone numbers)
UK_REGULATORY_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AU_REGULATORY_BUNDLE_SID=BUxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SINCH SMS (US-only - alternative to Twilio for US users)
# =============================================================================
#
# Setting all five vars below switches US users from Twilio to Sinch:
#   - Outbound: ChannelRouter::pick_channel_for() prefers `sinch` over `twilio`
#     for US users when SINCH_API_TOKEN is present (telnyx wins over both if
#     also configured).
#   - Inbound: /api/sinch/inbound and /api/sinch/status accept Sinch webhooks
#     when SINCH_CALLBACK_SECRET is present. The handler rejects users whose
#     phone country isn't US, so Sinch stays strictly US-only.
#
# Unset any of these to revert: outbound falls back to Twilio, inbound 401s.
SINCH_API_TOKEN=your-sinch-api-token
SINCH_SERVICE_PLAN_ID=your-sinch-service-plan-id
SINCH_US_FROM_NUMBER=+1234567890
# us | eu (default us)
SINCH_REGION=us
# Shared secret. Configure Sinch dashboard to send Authorization: Bearer <this>
# on every callback (inbound MO + delivery reports). Generate with `openssl rand -hex 32`.
SINCH_CALLBACK_SECRET=your-sinch-callback-secret

# =============================================================================
# TELNYX SMS (US-only - alternative to Twilio for US users)
# =============================================================================
#
# Setting all four required vars below switches US users from Twilio to Telnyx.
# If both Telnyx and Sinch are configured, Telnyx wins for US users (matches
# ChannelRouter::pick_channel_for ordering).
#
#   - Outbound: TELNYX_API_KEY + TELNYX_MESSAGING_PROFILE_ID + TELNYX_US_FROM_NUMBER
#     register the channel and route US users to it.
#   - Inbound: TELNYX_PUBLIC_KEY enables /api/telnyx/inbound and
#     /api/telnyx/status. Telnyx auto-signs every webhook with Ed25519; we
#     verify against this key. Handler rejects users whose phone country
#     isn't US (bypass via per-user preferred_sms_provider override).
#
# Unset any required var to revert: outbound falls back to Sinch/Twilio,
# inbound 401s.
TELNYX_API_KEY=KEY01XXXXXXXXX
TELNYX_MESSAGING_PROFILE_ID=400123456789012345
TELNYX_US_FROM_NUMBER=+1234567890
# Base64-encoded Ed25519 public key from Telnyx Mission Control Portal
# (Account Settings -> Public Key). 32 bytes when decoded.
TELNYX_PUBLIC_KEY=your-telnyx-public-key-base64
# Optional: USD per delivered message for credit deduction (default 0.004).
# Telnyx US SMS list price is around $0.004 per segment.
# TELNYX_USD_PER_MESSAGE=0.004

# =============================================================================
# PHONE NUMBERS (country-specific Twilio numbers)
# =============================================================================

# Phone numbers in E.164 format
USA_PHONE=+1234567890
FIN_PHONE=+358123456789
AUS_PHONE=+61123456789
GB_PHONE=+44123456789
CAN_PHONE=+1234567890
NL_PHONE=+31123456789

# ElevenLabs phone number IDs (for voice calls)
USA_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx
FIN_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx
AUS_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx
GB_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx
CAN_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx
NL_PHONE_NUMBER_ID=phnum_xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SHAZAM (Music Recognition)
# =============================================================================

SHAZAM_PHONE_NUMBER=+1234567890
SHAZAM_API_KEY=your-shazam-api-key

# =============================================================================
# ELEVENLABS VOICE AI
# =============================================================================

ELEVENLABS_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxx
ELEVENLABS_SERVER_URL_SECRET=your-server-url-secret
ELEVENLABS_WEBHOOK_SECRET=wsec_xxxxxxxxxxxxxxxxxxxxx

# ElevenLabs agent/assistant ID (ASSISTANT_ID is required by validation)
ASSISTANT_ID=your-assistant-id
# AGENT_ID takes precedence if both are set
AGENT_ID=your-agent-id

# Voice IDs for different languages
US_VOICE_ID=xxxxxxxxxxxxxxxxxxxxx
FI_VOICE_ID=xxxxxxxxxxxxxxxxxxxxx
DE_VOICE_ID=xxxxxxxxxxxxxxxxxxxxx

# Cost settings
VOICE_SECOND_COST=0.0033
CHARGE_BACK_THRESHOLD=2.00

# =============================================================================
# AI/LLM PROVIDERS
# =============================================================================

# OpenRouter (required)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxx

# OpenAI Realtime (optional - premium voice calls)
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_REASONING_EFFORT=low

# Perplexity (required for search)
PERPLEXITY_API_KEY=pplx-xxxxxxxxxxxxxxxxxxxxx

# Tinfoil (optional - privacy-focused LLM alternative)
# TINFOIL_API_KEY=tk_xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# YOUTUBE OAUTH (optional)
# =============================================================================

YOUTUBE_CLIENT_ID=xxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx

# =============================================================================
# TESLA OAUTH
# =============================================================================

TESLA_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
TESLA_CLIENT_SECRET=ta-secret.xxxxxxxxxxxxx
TESLA_REDIRECT_URL=https://your-domain.com
# Optional HTTP proxy for Tesla API
# TESLA_HTTP_PROXY_URL=https://localhost:4443

# =============================================================================
# STRIPE PAYMENTS
# =============================================================================

# Stripe API keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICING_TABLE_ID=prctbl_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# Product IDs
STRIPE_CREDITS_PRODUCT_ID=prod_xxxxxxxxxxxxx

# Subscription price IDs (create these in your Stripe dashboard)
STRIPE_SUBSCRIPTION_WORLD_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_HOSTED_PLAN_PRICE_ID_US=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_SELF_HOSTING_PRICE_ID=price_xxxxxxxxxxxxx

# Sentinel tier regional pricing
STRIPE_SUBSCRIPTION_SENTINEL_PRICE_ID_FI=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_SENTINEL_PRICE_ID_NL=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_SENTINEL_PRICE_ID_UK=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_SENTINEL_PRICE_ID_AU=price_xxxxxxxxxxxxx
STRIPE_SUBSCRIPTION_SENTINEL_PRICE_ID_OTHER=price_xxxxxxxxxxxxx

# Plan price IDs
STRIPE_DIGEST_PLAN_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_MONITOR_PLAN_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_BYOT_PLAN_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_ASSISTANT_PLAN_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_ASSISTANT_PLAN_PRICE_ID_US=price_xxxxxxxxxxxxx
STRIPE_AUTOPILOT_PLAN_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AUTOPILOT_PLAN_PRICE_ID_US=price_xxxxxxxxxxxxx
STRIPE_ASSISTANT_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_AUTOPILOT_YEARLY_PRICE_ID=price_xxxxxxxxxxxxx

# =============================================================================
# MATRIX HOMESERVER & BRIDGES
# =============================================================================

# Matrix homeserver configuration
MATRIX_HOMESERVER=https://your-synapse-server.com
MATRIX_SHARED_SECRET=your-shared-registration-secret
MATRIX_HOMESERVER_PERSISTENT_STORE_PATH=/path/to/.matrix_store
TUWUNEL_ADMIN_USER_ID=1
# Direct room-history purge requires Tuwunel >=1.8.1. Enable in dry-run first,
# inspect diagnostics, then set DRY_RUN=false. The admin user's Matrix session
# supplies the access token; no separate admin room or token is needed.
TUWUNEL_EVENT_PURGE_ENABLED=false
TUWUNEL_EVENT_PURGE_DRY_RUN=true
TUWUNEL_EVENT_PURGE_RETENTION_SECS=60
TUWUNEL_EVENT_PURGE_POLL_SECS=30
TUWUNEL_EVENT_PURGE_MAX_ATTEMPTS=5
TUWUNEL_EVENT_PURGE_BATCH_SIZE=10
# Historical scans are read-only by default and persist verified/blocked audit
# rows. Destructive backfill remains separately disabled until audits pass.
TUWUNEL_EVENT_PURGE_BACKFILL_ENABLED=false
TUWUNEL_EVENT_PURGE_BACKFILL_AUDIT_ENABLED=true
# Requires both this and BACKFILL_ENABLED before verified audits can enqueue.
TUWUNEL_EVENT_PURGE_BACKFILL_EXECUTE_VERIFIED_ENABLED=false
TUWUNEL_EVENT_PURGE_BACKFILL_BATCH_SIZE=25
TUWUNEL_EVENT_PURGE_BACKFILL_SCAN_SECS=3600
TUWUNEL_EVENT_PURGE_BACKFILL_MIN_AGE_SECS=86400
TUWUNEL_EVENT_PURGE_BACKFILL_AUDIT_RECHECK_SECS=86400
TUWUNEL_EVENT_PURGE_BACKFILL_AUDIT_MAX_PAGES=100
TUWUNEL_EVENT_PURGE_BACKFILL_AUDIT_PAGE_SIZE=100
TUWUNEL_EVENT_PURGE_STALE_INGEST_SECS=300
TUWUNEL_EVENT_PURGE_EXHAUSTED_RETRY_SECS=900
# Disconnected-platform cleanup snapshots room IDs before the bridge row is
# removed, then checks for reconnects and other active room owners. Confirmed
# explicit disconnects delete at most one room per cycle; legacy orphans remain
# separately disabled and unverified.
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_AUDIT_ENABLED=true
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_ENABLED=true
TUWUNEL_DISCONNECTED_BRIDGE_ORPHAN_PURGE_ENABLED=false
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_GRACE_SECS=120
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_POLL_SECS=30
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_MAX_ATTEMPTS=5
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_RETRY_SECS=300
TUWUNEL_DISCONNECTED_BRIDGE_ORPHAN_SCAN_SECS=3600
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_BATCH_SIZE=5
TUWUNEL_DISCONNECTED_BRIDGE_PURGE_ROOM_LIMIT=1

# Bridge bot user IDs (format: @botname:your-server.com)
WHATSAPP_BRIDGE_BOT=@whatsappbot:your-server.com
TELEGRAM_BRIDGE_BOT=@telegrambot:your-server.com
SIGNAL_BRIDGE_BOT=@signalbot:your-server.com

# =============================================================================
# EXTERNAL APIS
# =============================================================================

# Firecrawl (web scraping)
FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxx

# Geoapify (geolocation)
GEOAPIFY_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# Pirate Weather (weather data)
PIRATE_WEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# Composio (integration platform)
COMPOSIO_API_KEY=xxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# ENCLAVE / VSOCK PROXY (optional - only for Nitro Enclave deployment)
# =============================================================================

# HTTP proxy for external API calls (Twilio, OpenAI, etc.)
# Only set these when running inside a Nitro Enclave
# In normal VPS mode, leave these unset for direct internet access
# HTTP_PROXY=http://localhost:3128
# HTTPS_PROXY=http://localhost:3128

# =============================================================================
# PER-USER TWILIO CREDENTIALS (for self-hosted tier 3)
# Format: TWILIO_ACCOUNT_SID_{user_id}, TWILIO_AUTH_TOKEN_{user_id}, etc.
# =============================================================================

# Example for user ID 1:
# TWILIO_ACCOUNT_SID_1=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN_1=your-auth-token
# TWILIO_USER_PHONE_NUMBER_1=+1234567890
# TWILIO_USER_PHONE_NUMBER_ID_1=phnum_xxxxxxxxxxxxxxxxxxxxx
