# Lightfriend Environment Configuration
# Copy this file to .env and fill in your actual values
# Generate secrets with: just generate-secrets

# ============================================================================
# Database Configuration (for bridge PostgreSQL databases)
# ============================================================================
POSTGRES_PASSWORD=postgres

# ============================================================================
# JWT Authentication (REQUIRED)
# ============================================================================
# Generate with: openssl rand -base64 32
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_REFRESH_KEY=your-jwt-refresh-key-here

# ============================================================================
# Encryption (REQUIRED)
# ============================================================================
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=your-encryption-key-here
MAINTENANCE_SECRET=your-maintenance-secret-here

# Backup snapshot encryption is derived inside the enclave in production.
# For local development only, you may opt into the insecure fallback below.
ALLOW_INSECURE_BACKUP_KEY_FALLBACK=false
BACKUP_ENCRYPTION_KEY=
MARLIN_ROOT_SERVER_ENDPOINT=arbone-v4.kms.box:1100
MARLIN_ROOT_SERVER_X25519_PUBKEY=5ee189d3b990c284ebfe7fc4c2e1cecdb2a6908d0a1aa152592d30066061b92c
MARLIN_KMS_CONTRACT_ADDRESS=
MARLIN_BACKUP_KEY_PATH=lightfriend.backup.v1
MARLIN_BACKUP_KEY_COMMAND=

# ============================================================================
# Matrix Homeserver (REQUIRED)
# ============================================================================
# Registration token for creating new Matrix users (Tuwunel UIAA flow)
# Generate with: openssl rand -hex 32
MATRIX_REGISTRATION_TOKEN=your-matrix-registration-token-here

# Shared secret for bridge double puppeting
# Generate with: openssl rand -hex 32
MATRIX_HOMESERVER_SHARED_SECRET=your-matrix-shared-secret-here

# ============================================================================
# Twilio (Optional - for SMS/Voice)
# ============================================================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================================================
# Stripe (Optional - for payments)
# ============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_ASSISTANT_PLAN_PRICE_ID=
STRIPE_ASSISTANT_PLAN_PRICE_ID_US=
STRIPE_AUTOPILOT_PLAN_PRICE_ID=
STRIPE_AUTOPILOT_PLAN_PRICE_ID_US=
STRIPE_BYOT_PLAN_PRICE_ID=

# ============================================================================
# ElevenLabs (Optional - for voice AI)
# ============================================================================
ELEVENLABS_SERVER_URL_SECRET=
ELEVENLABS_WEBHOOK_SECRET=

# ============================================================================
# AI API Keys (REQUIRED: at least TINFOIL_API_KEY)
# ============================================================================
TINFOIL_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# ============================================================================
# Admin Emails (REQUIRED)
# ============================================================================
# Comma-separated list of admin email addresses
# Users with these emails get admin privileges
ADMIN_EMAILS=admin@example.com

# ============================================================================
# Resend API (Optional - for notification emails)
# ============================================================================
# Sign up at https://resend.com and get your API key
# If not set, notification emails will be skipped (logged as warnings)
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@lightfriend.ai

# ============================================================================
# Bootstrap Admin (Optional - only used if database is empty)
# ============================================================================
# On first startup, if no users exist, creates admin using FIRST email from ADMIN_EMAILS
# Password defaults to 12345678 - change it after first login!
BOOTSTRAP_ADMIN_PASSWORD=12345678
BOOTSTRAP_ADMIN_PHONE=+12345678

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development

# ============================================================================
# Sentry (Optional - for error tracking)
# ============================================================================
SENTRY_DSN=

# ============================================================================
# Telegram Bridge (get API keys from https://my.telegram.org/apps)
# ============================================================================
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telegram Proxy (Optional - if bridge runs from datacenter IP)
# Allowed types: disabled, socks4, socks5, http, mtproxy
TELEGRAM_PROXY_TYPE=disabled
TELEGRAM_PROXY_ADDRESS=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# ============================================================================
# Docker Core-Only Paths (Optional - for docker-compose.core-only.yml)
# ============================================================================
# These are only needed when running core standalone with existing Synapse/bridges
# Defaults work for local testing: ./data, ./matrix_store, ./uploads
#
# DATA_DIR=/var/lib/lightfriend
# MATRIX_STORE_DIR=/home/user/matrix-server/.matrix_store
# UPLOADS_DIR=/var/lib/lightfriend/uploads
# TESLA_PRIVATE_KEY=/path/to/tesla_private_key.pem
# TESLA_PUBLIC_KEY=/path/to/tesla_public_key.pem
# CORE_IMAGE=ahtavarasmus/lightfriend-core:latest

# ============================================================================
# Bridge Configuration
# ============================================================================
# NOTE: Bridge tokens (as_token, hs_token) are now AUTO-GENERATED!
# The setup script runs each bridge with -g flag to generate random tokens.
# You only need to provide the Double Puppet secret below.

# Double Puppet Secret (shared across all bridges)
# Generate with: openssl rand -base64 32
DOUBLE_PUPPET_SECRET=

# ============================================================================
# Infrastructure - AWS Nitro Enclave Setup
# ============================================================================
# See docs/INFRASTRUCTURE_SETUP.md for detailed setup instructions

# Terraform Cloud (for shared state management)
TF_CLOUD_ORG=
TF_CLOUD_TOKEN=

# AWS Region
AWS_REGION=us-east-1

# Cloudflare Zero Trust (for secure tunneling)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=

# ============================================================================
# Enclave VSOCK Proxy (only for Nitro Enclave deployment)
# ============================================================================
# HTTP proxy for external API calls when running inside enclave.
# Traffic routes through VSOCK to parent instance's HTTP proxy (e.g., Squid).
# Leave unset for normal VPS mode (direct internet access).
#
# HTTP_PROXY=http://localhost:3128
# HTTPS_PROXY=http://localhost:3128
