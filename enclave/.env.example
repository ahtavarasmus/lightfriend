# Lightfriend Enclave Environment Variables
# Copy to .env and fill in values before running.

# ── Core (always required) ────────────────────────────────────────────────────
JWT_SECRET_KEY=
JWT_REFRESH_KEY=
ENCRYPTION_KEY=
PG_DATABASE_URL=postgres://lightfriend:lightfriend@localhost:5432/lightfriend_db?sslmode=disable

# ── Matrix Homeserver ─────────────────────────────────────────────────────────
MATRIX_HOMESERVER=http://localhost:8008
MATRIX_SHARED_SECRET=
MATRIX_HOMESERVER_SHARED_SECRET=
MATRIX_REGISTRATION_TOKEN=
MATRIX_HOMESERVER_PERSISTENT_STORE_PATH=/app/matrix_store
DOUBLE_PUPPET_SECRET=

# Matrix bridge bots (auto-set by entrypoint, override only if needed)
WHATSAPP_BRIDGE_BOT=@whatsappbot:localhost
SIGNAL_BRIDGE_BOT=@signalbot:localhost
TELEGRAM_BRIDGE_BOT=@telegrambot:localhost

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=
BOOTSTRAP_ADMIN_PASSWORD=12345678
BOOTSTRAP_ADMIN_PHONE=+12345678

# ── Runtime ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
PORT=3000
FRONTEND_URL=
SERVER_URL=
ASSISTANT_ID=

# ── Production-required (only checked when ENVIRONMENT=production) ────────────

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CREDITS_PRODUCT_ID=
STRIPE_ASSISTANT_PLAN_PRICE_ID=
STRIPE_ASSISTANT_PLAN_PRICE_ID_US=
STRIPE_AUTOPILOT_PLAN_PRICE_ID=
STRIPE_AUTOPILOT_PLAN_PRICE_ID_US=

# Twilio SMS/Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# ElevenLabs voice AI
ELEVENLABS_SERVER_URL_SECRET=
ELEVENLABS_WEBHOOK_SECRET=

# Regional phone numbers
FIN_PHONE=
USA_PHONE=
AUS_PHONE=
GB_PHONE=
NL_PHONE=
CAN_PHONE=

# ElevenLabs phone number IDs
USA_PHONE_NUMBER_ID=
FIN_PHONE_NUMBER_ID=
AUS_PHONE_NUMBER_ID=
GB_PHONE_NUMBER_ID=
NL_PHONE_NUMBER_ID=
CAN_PHONE_NUMBER_ID=

# ── Optional (gracefully degrade if unset) ────────────────────────────────────
OPENROUTER_API_KEY=
TINFOIL_API_KEY=
PERPLEXITY_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@lightfriend.ai

# ── Telegram bridge ──────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PROXY_TYPE=
TELEGRAM_PROXY_ADDRESS=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# ── Enclave mode ──────────────────────────────────────────────────────────────
SKIP_BACKEND=false
BACKUP_ENCRYPTION_KEY=

# ── Cloudflare tunnel (Nitro Enclave only) ──────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ── S3 backup (for data migration between instances) ───────────────────────
S3_BACKUP_BUCKET=

# ── VSOCK proxy (Nitro Enclave only) ─────────────────────────────────────────
# These are set automatically inside the enclave when /dev/vsock is detected.
# HTTP_PROXY=
# HTTPS_PROXY=
